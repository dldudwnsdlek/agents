# config.yaml.example — Hermes 프로필 설정 예시
#
# 실제 파일 위치: ~/.hermes/profiles/<프로필명>/config.yaml
# API 키는 여기 두지 말고 같은 폴더의 .env 에 둔다.
# (키 이름은 Hermes 버전에 따라 다를 수 있으니 `hermes config` 또는 `hermes setup`으로 확인)

# --- 모델/프로바이더 ---
provider: anthropic                 # openrouter | anthropic | openai | nous | ollama | custom
model: claude-opus-4-8              # 단계별로 바꿔도 됨(아래 "단계별 모델 팁" 참고)

# --- 툴셋(단계마다 필요한 것만 켜면 안전/저렴) ---
toolsets:
  - web        # 수집자/분석가: 검색·웹 추출
  - terminal   # 파일 입출력(workspace 읽고/쓰기)
  - skills     # SKILL.md 로딩

# --- 작업 디렉터리(터미널 명령 기준 경로) ---
terminal:
  cwd: "~/job-agents"               # 이 레포를 클론/배치한 경로로 맞춘다

# --- 행동 설정(선택) ---
behavior:
  autonomy: medium                  # 파이프라인은 비대화형(-z)으로 돌리므로 과한 질문 억제
  confirm_before_writes: false      # workspace 자동 저장 허용

# .env (같은 폴더, 커밋 금지) 예시:
#   ANTHROPIC_API_KEY=sk-ant-...
#   # 또는 OPENROUTER_API_KEY=...

# --- 단계별 모델 팁(비용 최적화) ---
# 수집자/분석가: 웹 리서치가 많음 → 빠르고 저렴한 모델도 가능
# 평가자/결정자: 판단력 중요 → 상위 추론 모델 권장(claude-opus-4-8 등)
# 작성자: 문장력 중요 → 상위 모델 권장
# 프로필별 config.yaml의 model 값만 바꾸면 단계마다 다른 모델 사용 가능.
